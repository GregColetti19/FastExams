# Local development defaults (loaded only when NODE_ENV=development, i.e. `next dev`).
# Production builds do NOT load this file, so it never affects a real deploy.
#
# Mock DB is the default for local dev: token-free, no cloud, server + browser
# share one in-memory store via /api/dev-db. NEXT_PUBLIC_DB_MODE must be set here
# (not just on the command line) so Next reliably inlines it into the browser
# bundle — otherwise the client falls back to a real Supabase client and fails.
#
# To use a real Supabase in dev instead, set DB_MODE=real in .env.local (which
# overrides this file) and provide real NEXT_PUBLIC_SUPABASE_URL/ANON_KEY.
DB_MODE=mock
NEXT_PUBLIC_DB_MODE=mock
DEV_DB_PERSIST=1
DEV_DB_PATH=.dev-data/db.json
# Token-free by default: uploads/generation use canned AI fixtures, not real
# Claude/OpenAI. Set MOCK_AI=false in .env.local to run the real pipeline.
MOCK_AI=true
