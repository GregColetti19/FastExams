# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — NEVER put real secrets in this .example file (it is committed).

# Supabase
NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key  # server-side only — bypasses RLS

# Anthropic
ANTHROPIC_API_KEY=your-anthropic-key

# OpenAI (Phase 2+ — embeddings)
OPENAI_API_KEY=your-openai-key

# Processing
CONVERTER_SERVICE_URL=http://localhost:8001
MAX_FILE_SIZE_MB=300
QUESTIONS_PER_CHUNK=5
PDF_MIN_CHARS_PER_PAGE=100  # below this → escalate to Docling

# Local dev toggles (token-free, no cloud)
# DB_MODE=mock    # use in-memory DB instead of Supabase
# MOCK_AI=true    # return canned AI fixtures instead of calling Anthropic
