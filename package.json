{
  "name": "fastexams",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:debug": "concurrently \"next dev\" \"sleep 2 && open 'chrome://inspect'\"",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ai": "vitest run lib/ai",
    "test:converter": "cd converter && ./venv/bin/python test_converter.py --direct",
    "converter": "cd converter && ./venv/bin/python main.py",
    "dev:all": "concurrently -n next,converter -c blue,green \"next dev\" \"npm run converter\"",
    "dev:seed": "node scripts/seed-dev.mjs",
    "dev:mock": "DB_MODE=mock NEXT_PUBLIC_DB_MODE=mock DEV_DB_PERSIST=1 concurrently -n next,converter -c blue,green \"next dev\" \"npm run converter\"",
    "start:oneclick": "./start-dev.sh"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.102.0",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.107.0",
    "franc": "^5.0.0",
    "next": "14.2.35",
    "react": "^18",
    "react-dom": "^18"
  },
  "devDependencies": {
    "@radix-ui/react-accordion": "^1.2.13",
    "@radix-ui/react-dialog": "^1.1.16",
    "@radix-ui/react-dropdown-menu": "^2.1.17",
    "@radix-ui/react-popover": "^1.1.16",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "concurrently": "^10.0.3",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "lucide-react": "^1.17.0",
    "postcss": "^8",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^3.4.1",
    "typescript": "^5",
    "vitest": "^2.1.9"
  }
}
